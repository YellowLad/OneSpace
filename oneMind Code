<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OneWorld</title>
  <style>
    body {
      background: #03050A;
      color: #EEF2F8;
      font-family: 'Inter', sans-serif;
      margin: 0;
      padding: 0;
    }
    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem;
    }
    .btn {
      background: linear-gradient(135deg, #F5B041, #D4AF37);
      border: none;
      border-radius: 40px;
      padding: 0.5rem 1rem;
      cursor: pointer;
      margin: 0.5rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>OneWorld</h1>
    <div id="app"></div>
    
    <!-- UI Controls -->
    <div class="controls">
      <button class="btn" id="shareBtn">Share</button>
      <button class="btn" id="optionsBtn">Options</button>
      <button class="btn" id="expandBtn">+</button>
    </div>
  </div>

  <script>
    // Core OneWorld Logic
    const app = document.getElementById('app');
    app.innerHTML = <p>The Way holds. 🧢💫</p>;

    // UI Button Functionality
    document.getElementById('shareBtn').addEventListener('click', () => {
      navigator.share?.({
        title: 'OneWorld',
        text: 'Explore The Way',
        url: window.location.href
      }).catch(() => alert('Link copied to clipboard'));
    });

    document.getElementById('optionsBtn').addEventListener('click', () => {
      alert('Options: Toggle Dark Mode | Reset Session | About');
    });

    document.getElementById('expandBtn').addEventListener('click', () => {
      app.innerHTML += <p>Expanded details here...</p>;
    });

    // Service Worker for Offline Use
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js');
    }
  </script>
</body>
</html>

2. sw.js (Service Worker)
javascript
// Cache OneWorld for offline use
const CACHE_NAME = 'oneworld-v1';
const ASSETS = [
  '/',
  '/index.html',
  '/styles.css',
  '/app.js'
];

self.addEventListener('install', (e) => {
  e.waitUntil(
    caches.open(CACHE_NAME)
      .then(cache => cache.addAll(ASSETS))
  );
});

self.addEventListener('fetch', (e) => {
  e.respondWith(
    caches.match(e.request)
      .then(response => response || fetch(e.request))
  );
});

3. deploy.sh (Netlify Deployment Script)
bash
#!/bin/bash
Auto-deploys OneWorld to Netlify
Step 1: Clone from Replit (if needed)
git clone https://github.com/your-repo/oneworld.git
cd oneworld
Step 2: Prepare build folder
mkdir -p dist && cp index.html sw.js dist/
Step 3: Deploy to Netlify (requires netlify-cli)
npm install -g netlify-cli
netlify deploy --prod --dir=dist

echo "Deployed to: https://your-site.netlify.app"

